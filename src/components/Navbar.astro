---
import { information } from "@data";
import { createLogo } from "@utils";
import { MoonIcon, SunIcon, MenuIcon } from "@assets";
import NavItem from "@components/NavItem.astro";
import LinkItem from "@components/LinkItem.astro";
---

<header
  class="container flex h-[80px] items-center justify-between sm:h-[123px]"
>
  <a class="font-outfit text-2xl font-semibold" href="/"
    >{createLogo(information.name)}.
  </a>
  <nav class="flex items-center">
    <button
      id="dropdownButton"
      data-dropdown-toggle="dropdown"
      class="order-first ml-2 flex items-center rounded-lg bg-slate-200 p-4 focus:outline-none focus:ring focus:ring-sky-300 md:order-last md:hidden"
      type="button"
    >
      <Fragment set:html={MenuIcon} />
    </button>
    <!-- Dropdown menu -->
    <div
      id="dropdown"
      class="right-4 z-10 hidden w-56 origin-top-right translate-y-36 rounded-lg bg-base px-4 shadow-lg ring-1 ring-black ring-opacity-5 dark:bg-surface0 md:mt-0 md:flex md:w-auto md:translate-x-0 md:translate-y-0 md:items-center md:shadow-none md:ring-0"
    >
      <ul class="flex flex-col items-center md:w-auto md:flex-row md:gap-4">
        <NavItem text="Experiencia" link="#experience" />
        <NavItem text="Educación" link="#education" />
        <NavItem text="Habilidades" link="#skills" />
        <NavItem text="Proyectos" link="#projects" />
        <NavItem text="Contacto" link="#contact" />
      </ul>
    </div>
    <LinkItem id="theme-button" title="toggle">
      <div id="theme-icon" class="order-first text-dark md:order-last"></div>
    </LinkItem>
  </nav>
</header>

<script is:inline define:vars={{ MoonIcon, SunIcon }}>
  const themeButton = document.getElementById("theme-button");
  const themeButtonIcon = document.getElementById("theme-icon");
  const themeButtonText = document.querySelector("#theme-button > span");
  const themeBodyClass = document.body;
  const browserTheme = document.querySelector('[name="theme-color"]');
  let isLight;

  // Change the docuemnt color
  const toggleTheme = () => {
    const newTheme = isLight ? "dark" : "light";
    isLight = !isLight;
    localStorage.setItem("theme", newTheme);
    applyTheme();
  };

  const applyTheme = () => {
    setDocumentAttributes(
      isLight ? "light" : "dark",
      isLight ? SunIcon : MoonIcon,
      isLight ? "#EFF1F5" : "#1E1E2E",
    );
    themeBodyClass.classList.toggle("dark", !isLight);
    themeBodyClass.classList.toggle("mocha", !isLight);
  };

  const setDocumentAttributes = (dataTheme, themeIcon, browserColor) => {
    browserTheme.content = browserColor;
    themeButtonText.textContent = dataTheme;
    themeButtonIcon.innerHTML = themeIcon;
  };

  themeButton.addEventListener("click", toggleTheme);

  // Initialize the theme
  const initialTheme = (() => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
      return "dark";
    }
    return "light";
  })();

  applyTheme(initialTheme);
</script>

<script is:inline>
  const dropdownButton = document.getElementById("dropdownButton");
  const menu = document.getElementById("dropdown");

  dropdownButton.addEventListener("click", () => {
    menu.classList.toggle("hidden");
    menu.classList.toggle("absolute");
  });
</script>
