---
import Section from "@components/Section.astro";
import { SkillSet } from "@types";
const { title, skillSets, ...props } = Astro.props as {
  title: string;
  skillSets: SkillSet[];
};
---

<Section title={title} {...props}>
  {
    skillSets.map(({ title, list }) => {
      return (
        <article class="my-8 first:mt-8 md:first:mt-16">
          <h3 class="text-xl font-semibold text-lavender">{title}</h3>
          <div class="my-4">
            <img src={list} alt="Skills">
          </div>
        </article>
      );
    })
  }
</Section>
