---
import Section from "@components/Section.astro";
import { Experiences } from "@types";

const { title, details, ...attrs } = Astro.props as Experiences;
---

<Section title={title} {...attrs}>
  {
    details.map((item) => (
      <article class="my-8 first:mt-8 md:first:mt-16 separ">
        <div class="flex flex-wrap items-center justify-between">
          <h3 class="text-xl font-semibold">
            {item.position} -{" "} {item.name}
          </h3>
          <p class="text-sm ">
            {item.startDate} - {item.endDate}
          </p>
        </div>
        <ul class="mt-3">
          {item.description.map((item) => (
            <li class="list-disc marker:text-blue" set:html={item} />
          ))}
        </ul>
      </article>
    ))
  }
</Section>
